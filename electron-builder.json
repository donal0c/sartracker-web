{
  "appId": "ie.sartracker.validation",
  "productName": "SAR Tracker Electron Validation",
  "artifactName": "sartracker-electron-validation_${version}_${os}_${arch}.${ext}",
  "directories": {
    "output": "tmp/electron-dist"
  },
  "files": [
    "dist/**",
    "electron/**",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "field-tools",
      "to": "field-tools",
      "filter": [
        "**/*"
      ]
    }
  ],
  "asar": true,
  "npmRebuild": true,
  "buildDependenciesFromSource": true,
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility",
    "maintainer": "SAR Tracker",
    "synopsis": "SAR Tracker Electron validation build"
  },
  "win": {
    "target": [
      "nsis"
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  }
}
